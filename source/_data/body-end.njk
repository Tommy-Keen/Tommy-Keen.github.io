<script>
document.addEventListener('page:loaded', () => {
  if (!CONFIG.page.isPost) return;

  const container = document.querySelector('.giscus-container');
  if (!container) return;

  NexT.utils.loadComments('.giscus-container')
    .then(() => NexT.utils.getScript('https://giscus.app/client.js', {
      attributes: {
        async                   : true,
        crossOrigin             : 'anonymous',
        'data-repo'             : 'Tommy-Keen/Tommy-Keen.github.io',
        'data-repo-id'          : 'R_kgDOHVVyYA',
        'data-category'         : 'Announcements',
        'data-category-id'      : 'DIC_kwDOHVVyYM4DAlL9',
        'data-mapping'          : 'pathname',
        'data-strict'           : '0',
        'data-reactions-enabled': '1',
        'data-emit-metadata'    : '0',
        'data-input-position'   : 'bottom',
        'data-theme'            : 'light',
        'data-lang'             : 'zh-CN',
        'data-loading'          : 'lazy'
      },
      parentNode: container
    }));
});
</script>

<script>
document.addEventListener('page:loaded', () => {
  document.querySelectorAll('.pdf-preview').forEach(block => {
    const button = block.querySelector('.pdf-preview-button');
    const frameWrap = block.querySelector('.pdf-preview-frame');
    const pdfUrl = block.dataset.pdfUrl;

    if (!button || !frameWrap || !pdfUrl) return;
    if (button.dataset.bound === 'true') return;
    button.dataset.bound = 'true';

    button.addEventListener('click', () => {
      if (!frameWrap.querySelector('iframe')) {
        const iframe = document.createElement('iframe');
        iframe.src = pdfUrl;
        iframe.loading = 'lazy';
        iframe.title = 'PDF Preview';
        frameWrap.appendChild(iframe);
        frameWrap.classList.remove('is-collapsed');
        button.textContent = '收起预览';
        return;
      }

      const isCollapsed = frameWrap.classList.toggle('is-collapsed');
      button.textContent = isCollapsed ? '展开预览' : '收起预览';
    });
  });
});
</script>

